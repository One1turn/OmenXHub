<Window x:Class="OmenSuperHub.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OMEN X Hub 控制面板" Width="820" Height="580"
        WindowStartupLocation="CenterScreen" Topmost="True"
        ResizeMode="NoResize" ShowInTaskbar="True"
        Style="{StaticResource OmenWindow}"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

  <Border Background="{StaticResource BgDeepBrush}" CornerRadius="12" Margin="10">
    <Border.Effect>
      <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black" Opacity="0.4"/>
    </Border.Effect>
    <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- WINDOW CONTROLS (Top Right Overlay) -->
    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0" Panel.ZIndex="999">
      <Button Content="-" Style="{StaticResource OmenButton}" Width="32" Height="32" Padding="0"
              FontSize="16" Background="Transparent" BorderThickness="0"
              Click="MinimizeButton_Click"/>
      <Button Content="✕" Style="{StaticResource OmenButton}" Width="32" Height="32" Padding="0"
              FontSize="14" Background="Transparent" BorderThickness="0" Margin="4,0,0,0"
              Click="CloseButton_Click"/>
    </StackPanel>

    <!-- ══════ LEFT NAV ══════ -->
    <Border Grid.Column="0" Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,1,0"
            CornerRadius="12,0,0,12">
      <DockPanel>
        <!-- Logo -->
        <StackPanel DockPanel.Dock="Top" Margin="20,24,20,24">
          <Image Source="/OmenXHub;component/Resources/1.png" Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"/>
          <TextBlock FontSize="16" FontWeight="Bold" FontFamily="Microsoft YaHei UI, Segoe UI">
            <Run Text="OMEN" Foreground="{StaticResource AccentOmenBrush}"/>
            <Run Text="X Hub" Foreground="{StaticResource TextPrimaryBrush}"/>
          </TextBlock>
          <TextBlock x:Name="VersionText" Style="{StaticResource OmenCaption}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Version at bottom -->
        <TextBlock DockPanel.Dock="Bottom" x:Name="StatusBarText"
                   Style="{StaticResource OmenCaption}" Margin="16,0,16,12"
                   TextWrapping="Wrap" FontSize="10"/>

        <!-- Nav Buttons -->
        <StackPanel Margin="8,0">
          <RadioButton x:Name="NavDashboard" Style="{StaticResource OmenNavButton}"
                       Content="总览" Tag="📊" IsChecked="True"
                       Checked="NavButton_Checked"/>
          <RadioButton x:Name="NavFan" Style="{StaticResource OmenNavButton}"
                       Content="风扇" Tag="🌀"
                       Checked="NavButton_Checked"/>
          <RadioButton x:Name="NavPerf" Style="{StaticResource OmenNavButton}"
                       Content="性能" Tag="⚡"
                       Checked="NavButton_Checked"/>
          <RadioButton x:Name="NavSettings" Style="{StaticResource OmenNavButton}"
                       Content="设置" Tag="⚙"
                       Checked="NavButton_Checked"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ══════ CONTENT AREA ══════ -->
    <Grid Grid.Column="1">

      <!-- ══════ PAGE: DASHBOARD ══════ -->
      <ScrollViewer x:Name="PageDashboard" VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource OmenScrollViewer}">
        <StackPanel Margin="24,20">
          <TextBlock Text="实时状态" Style="{StaticResource OmenHeading}" Margin="0,0,0,16"/>

          <!-- CPU/GPU Temps -->
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU Card -->
            <Border Grid.Column="0" Style="{StaticResource OmenGroupCard}">
              <StackPanel>
                <TextBlock Text="CPU" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                  <TextBlock x:Name="CpuTempText" Style="{StaticResource OmenStatValue}" Text="--"/>
                  <TextBlock Style="{StaticResource OmenStatUnit}" Text="°C"/>
                </StackPanel>
                <TextBlock x:Name="CpuFanText" Style="{StaticResource OmenCaption}" Margin="0,6,0,0"/>
                <TextBlock x:Name="CpuPowerText" Style="{StaticResource OmenCaption}" Margin="0,2,0,0"/>
              </StackPanel>
            </Border>

            <!-- GPU Card -->
            <Border Grid.Column="2" Style="{StaticResource OmenGroupCard}">
              <StackPanel>
                <TextBlock Text="GPU" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                  <TextBlock x:Name="GpuTempText" Style="{StaticResource OmenStatValue}" Text="--"/>
                  <TextBlock Style="{StaticResource OmenStatUnit}" Text="°C"/>
                </StackPanel>
                <TextBlock x:Name="GpuFanText" Style="{StaticResource OmenCaption}" Margin="0,6,0,0"/>
                <TextBlock x:Name="GpuPowerText" Style="{StaticResource OmenCaption}" Margin="0,2,0,0"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Quick Status -->
          <Border Style="{StaticResource OmenGroupCard}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <TextBlock Text="性能模式" Style="{StaticResource OmenCaption}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CurrentModeText" Foreground="{StaticResource AccentOmenBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="风扇控制" Style="{StaticResource OmenCaption}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CurrentFanText" Foreground="{StaticResource AccentOmenBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                <TextBlock Text="电源状态" Style="{StaticResource OmenCaption}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PowerStatusText" Foreground="{StaticResource AccentGreenBrush}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" HorizontalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Quick Performance Mode Switcher -->
          <Border Style="{StaticResource OmenGroupCard}">
            <WrapPanel HorizontalAlignment="Center">
              <RadioButton x:Name="DashModeDefault"
                           GroupName="DashPerfMode" Content="⚡ 平衡模式"
                           Style="{StaticResource OmenOptionRadio}"
                           Checked="DashPerfMode_Checked"
                           Margin="0,0,6,0"/>
              <RadioButton x:Name="DashModePerformance"
                           GroupName="DashPerfMode" Content="🔥 狂暴模式"
                           Style="{StaticResource OmenOptionRadio}"
                           Checked="DashPerfMode_Checked"
                           Margin="6,0,0,0"/>
            </WrapPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ══════ PAGE: FAN ══════ -->
      <ScrollViewer x:Name="PageFan" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource OmenScrollViewer}">
        <StackPanel Margin="24,20">
          <TextBlock Text="风扇控制" Style="{StaticResource OmenHeading}" Margin="0,0,0,16"/>

          <!-- Fan Mode -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="风扇配置" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel>
                <RadioButton x:Name="FanModeSilent" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FanConfig" Content="安静模式" Checked="FanMode_Changed"/>
                <RadioButton x:Name="FanModeCool" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FanConfig" Content="降温模式" Checked="FanMode_Changed"/>
                <RadioButton x:Name="FanModeCustom" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FanConfig" Content="自定义曲线" Checked="FanMode_Changed"/>
                <RadioButton x:Name="FanModeManual" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FanConfig" Content="手动模式" Checked="FanMode_Changed"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- Temp Sensitivity (visible for 安静/降温/自定义) -->
          <Border x:Name="TempSensCard" Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="温度灵敏度" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel>
                <RadioButton x:Name="SensRealtime" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TempSens" Content="实时" Checked="Sensitivity_Checked"/>
                <RadioButton x:Name="SensHigh" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TempSens" Content="高" Checked="Sensitivity_Checked"/>
                <RadioButton x:Name="SensMedium" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TempSens" Content="中" Checked="Sensitivity_Checked"/>
                <RadioButton x:Name="SensLow" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TempSens" Content="低" Checked="Sensitivity_Checked"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- Manual Speed Control (visible only for 手动模式) -->
          <Border x:Name="ManualControlCard" Style="{StaticResource OmenGroupCard}" Visibility="Collapsed">
            <StackPanel>
              <TextBlock Text="转速控制" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel x:Name="FanControlPanel"/>
            </StackPanel>
          </Border>

          <!-- Custom Fan Curve Editor (visible only for 自定义曲线) -->
          <Border x:Name="FanCurveCard" Style="{StaticResource OmenGroupCard}" Visibility="Collapsed">
            <StackPanel>
              <TextBlock Text="自定义风扇曲线" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <TextBlock Text="拖拽控制点调整不同温度下的风扇转速" Style="{StaticResource OmenCaption}" Margin="0,0,0,12"/>
              <Grid>
                <!-- Y-Axis Labels -->
                <StackPanel Width="45" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,24">
                  <TextBlock Text="RPM" Style="{StaticResource OmenCaption}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                </StackPanel>
                <!-- Chart Area -->
                <Border Margin="45,0,10,24" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4">
                  <Canvas x:Name="FanCurveCanvas" Height="260" ClipToBounds="True"
                          Background="Transparent"
                          MouseLeftButtonDown="FanCurveCanvas_MouseLeftButtonDown"
                          MouseMove="FanCurveCanvas_MouseMove"
                          MouseLeftButtonUp="FanCurveCanvas_MouseLeftButtonUp"/>
                </Border>
                <!-- X-Axis Label -->
                <TextBlock Text="温度 (°C)" Style="{StaticResource OmenCaption}" HorizontalAlignment="Center"
                           VerticalAlignment="Bottom" Margin="45,0,10,4"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- ══════ PAGE: PERFORMANCE ══════ -->
      <ScrollViewer x:Name="PagePerf" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource OmenScrollViewer}">
        <StackPanel Margin="24,20">
          <TextBlock Text="性能控制" Style="{StaticResource OmenHeading}" Margin="0,0,0,16"/>

          <!-- Fan Mode -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="性能模式" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel>
                <RadioButton x:Name="ModePerformance" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FanMode" Content="🔥 狂暴模式" Checked="FanMode_Checked"/>
                <RadioButton x:Name="ModeDefault" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FanMode" Content="⚡ 平衡模式" Checked="FanMode_Checked"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- GPU Power -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="GPU 功率" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="12"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="CTGP" Style="{StaticResource OmenCaption}" Margin="0,0,0,6"/>
                  <ComboBox x:Name="CtgpCombo" Style="{StaticResource OmenComboBox}"
                            SelectionChanged="CtgpCombo_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Dynamic Boost" Style="{StaticResource OmenCaption}" Margin="0,0,0,6"/>
                  <ComboBox x:Name="DbPowerCombo" Style="{StaticResource OmenComboBox}"
                            SelectionChanged="DbPowerCombo_SelectionChanged"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- DB Version -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="DB 版本" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel>
                <RadioButton x:Name="DbUnlock" Style="{StaticResource OmenOptionRadio}"
                             GroupName="DBVer" Content="🔓 解锁版本" Checked="DbVersion_Checked"/>
                <RadioButton x:Name="DbNormal" Style="{StaticResource OmenOptionRadio}"
                             GroupName="DBVer" Content="📦 普通版本" Checked="DbVersion_Checked"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- CPU Power -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="CPU 功率" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <ComboBox x:Name="CpuPowerCombo" Style="{StaticResource OmenComboBox}"
                        SelectionChanged="CpuPower_SelectionChanged"/>
            </StackPanel>
          </Border>

          <!-- GPU Clock -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="GPU 频率限制" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <ComboBox x:Name="GpuClockCombo" Style="{StaticResource OmenComboBox}"
                        SelectionChanged="GpuClock_SelectionChanged"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- ══════ PAGE: SETTINGS ══════ -->
      <ScrollViewer x:Name="PageSettings" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource OmenScrollViewer}">
        <StackPanel Margin="24,20">
          <TextBlock Text="设置" Style="{StaticResource OmenHeading}" Margin="0,0,0,16"/>

          <!-- Floating Window -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="浮窗显示" Style="{StaticResource OmenSubHeading}"/>
                <ToggleButton x:Name="FloatingToggle" Grid.Column="1" Style="{StaticResource OmenToggle}"
                              Checked="FloatingToggle_Changed" Unchecked="FloatingToggle_Changed"/>
              </Grid>
              <TextBlock Text="字体大小" Style="{StaticResource OmenCaption}" Margin="0,0,0,6"/>
              <WrapPanel>
                <RadioButton x:Name="FloatSize24" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FloatSize" Content="24号" Checked="FloatSize_Checked"/>
                <RadioButton x:Name="FloatSize36" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FloatSize" Content="36号" Checked="FloatSize_Checked"/>
                <RadioButton x:Name="FloatSize48" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FloatSize" Content="48号" Checked="FloatSize_Checked"/>
              </WrapPanel>
              <TextBlock Text="位置" Style="{StaticResource OmenCaption}" Margin="0,8,0,6"/>
              <WrapPanel>
                <RadioButton x:Name="FloatLocLeft" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FloatLoc" Content="左上角" Checked="FloatLoc_Checked"/>
                <RadioButton x:Name="FloatLocRight" Style="{StaticResource OmenOptionRadio}"
                             GroupName="FloatLoc" Content="右上角" Checked="FloatLoc_Checked"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- Omen Key -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="Omen 键" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel>
                <RadioButton x:Name="OmenKeyDefault" Style="{StaticResource OmenOptionRadio}"
                             GroupName="OmenKey" Content="默认" Checked="OmenKey_Checked"/>
                <RadioButton x:Name="OmenKeyCustom" Style="{StaticResource OmenOptionRadio}"
                             GroupName="OmenKey" Content="切换浮窗显示" Checked="OmenKey_Checked"/>
                <RadioButton x:Name="OmenKeyNone" Style="{StaticResource OmenOptionRadio}"
                             GroupName="OmenKey" Content="取消绑定" Checked="OmenKey_Checked"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- Tray Icon -->
          <Border Style="{StaticResource OmenGroupCard}">
            <StackPanel>
              <TextBlock Text="托盘图标" Style="{StaticResource OmenSubHeading}" Margin="0,0,0,10"/>
              <WrapPanel>
                <RadioButton x:Name="IconOriginal" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TrayIcon" Content="原版" Checked="TrayIcon_Checked"/>
                <RadioButton x:Name="IconCustom" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TrayIcon" Content="自定义" Checked="TrayIcon_Checked"/>
                <RadioButton x:Name="IconDynamic" Style="{StaticResource OmenOptionRadio}"
                             GroupName="TrayIcon" Content="动态" Checked="TrayIcon_Checked"/>
              </WrapPanel>
            </StackPanel>
          </Border>

          <!-- Auto Start -->
          <Border Style="{StaticResource OmenGroupCard}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="开机自启" Style="{StaticResource OmenSubHeading}"/>
                <TextBlock Text="通过 Task Scheduler 设置开机自启动" Style="{StaticResource OmenCaption}" Margin="0,2,0,0"/>
              </StackPanel>
              <ToggleButton x:Name="AutoStartToggle" Grid.Column="1" Style="{StaticResource OmenToggle}"
                            Checked="AutoStartToggle_Changed" Unchecked="AutoStartToggle_Changed"/>
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>

    </Grid>
    </Grid>
  </Border>
</Window>
