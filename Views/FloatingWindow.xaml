<Window x:Class="OmenSuperHub.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False"
        SizeToContent="WidthAndHeight"
        Left="0" Top="0">

  <Border x:Name="ContentBorder" CornerRadius="8" Padding="14,10"
          Background="{DynamicResource BgCardBrush}"
          BorderBrush="{DynamicResource BorderDefaultBrush}"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270"
                        Color="#60000000" Opacity="0.4"/>
    </Border.Effect>

    <StackPanel x:Name="DataPanel">
      <!-- CPU Row -->
      <StackPanel Orientation="Horizontal" Margin="0,2">
        <TextBlock Text="CPU" FontFamily="Consolas, Microsoft YaHei UI" Width="32"
                   FontWeight="Bold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"
                   x:Name="CpuLabel"/>
        <TextBlock x:Name="CpuTempText" FontFamily="Consolas"
                   FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
        <TextBlock x:Name="CpuPowerText" FontFamily="Consolas"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- GPU Row -->
      <StackPanel x:Name="GpuRow" Orientation="Horizontal" Margin="0,2">
        <TextBlock Text="GPU" FontFamily="Consolas, Microsoft YaHei UI" Width="32"
                   FontWeight="Bold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"
                   x:Name="GpuLabel"/>
        <TextBlock x:Name="GpuTempText" FontFamily="Consolas"
                   FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
        <TextBlock x:Name="GpuPowerText" FontFamily="Consolas"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Fan Row -->
      <StackPanel x:Name="FanRow" Orientation="Horizontal" Margin="0,2">
        <TextBlock Text="FAN" FontFamily="Consolas, Microsoft YaHei UI" Width="32"
                   FontWeight="Bold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"
                   x:Name="FanLabel"/>
        <TextBlock x:Name="FanSpeedText" FontFamily="Consolas"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
