<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- OMEN THEME STYLES                                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- Note: Colors are defined in Colors.Dark.xaml / Colors.Light.xaml -->

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CONTEXT MENU (Tray Icon Menu)                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <DropShadowEffect x:Key="MenuShadow" BlurRadius="20" ShadowDepth="4"
                     Direction="270" Color="#80000000" Opacity="0.6"/>

  <Style x:Key="OmenContextMenu" TargetType="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource BgDeepBrush}"/> <!-- Hardcoded previously #F0141420, now using Brush? No, ContextMenu used hex. Let's use BgDeepBrush for consistency? Or stick to hex? Original used #F0141420. Regedit might be best. Let's use BgCardBrush for now or keep Hex if specific transparency. Original: #F0141420. Let's use DynamicResource BgCardBrush for theming support. -->
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="2,6"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="HasDropShadow" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContextMenu">
          <Border x:Name="Border" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8" Padding="{TemplateBinding Padding}"
                  Effect="{StaticResource MenuShadow}">
            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- MenuItem Style -->
  <Style x:Key="OmenMenuItem" TargetType="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Margin="2,1"
                  Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                <ColumnDefinition Width="16"/>
              </Grid.ColumnDefinitions>

              <!-- Check Mark -->
              <Grid x:Name="CheckMark" Grid.Column="0" Visibility="Collapsed" Margin="0,0,6,0">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </Grid>

              <!-- Header -->
              <ContentPresenter Grid.Column="1" ContentSource="Header"
                                RecognizesAccessKey="True" VerticalAlignment="Center"/>

              <!-- Submenu Arrow -->
              <Path x:Name="SubMenuArrow" Grid.Column="3" VerticalAlignment="Center"
                    Data="M 0 0 L 5 4 L 0 8 Z" Fill="{DynamicResource TextSecondaryBrush}"
                    HorizontalAlignment="Right" Visibility="Collapsed"/>

              <!-- Popup for submenu -->
              <Popup x:Name="PART_Popup" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                     Placement="Right" AllowsTransparency="True" Focusable="False"
                     PopupAnimation="Fade" HorizontalOffset="0" VerticalOffset="-8">
                <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="2,6"
                        Effect="{StaticResource MenuShadow}">
                  <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                </Border>
              </Popup>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="HasItems" Value="True">
              <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
              <!-- Highlight Color: Semitransparent Accent. Using AccentOmenBrush with Opacity? No, WPF doesn't support Opacity on Brush Ref directly easily in XAML without new resource.
                   Original: #30FF6B00.
                   For Dynamic Theme, we need a DynamicResource for Highlight.
                   Let's use BgHoverBrush for highlight to be safe, or just keep fixed for now?
                   Actually, let's use BgHoverBrush which is defined in Colors. -->
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <!-- And Text Color? Original: AccentOmenLightBrush. Let's use TextPrimaryBrush or TextAccentBrush. -->
              <Setter Property="Foreground" Value="{DynamicResource TextAccentBrush}"/>
              <Setter TargetName="SubMenuArrow" Property="Fill" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Separator Style for ContextMenu -->
  <Style x:Key="OmenMenuSeparator" TargetType="Separator">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="12,4"/>
    <Setter Property="Background" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1" Background="{TemplateBinding Background}" Margin="{TemplateBinding Margin}"
                  SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- WINDOW STYLE                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenWindow" TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource BgPrimaryBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- BUTTON STYLES                                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6" Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentOmenDimBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenAccentButton" TargetType="Button" BasedOn="{StaticResource OmenButton}">
    <Setter Property="Background" Value="{DynamicResource AccentOmenBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource BgDeepBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- TABCONTROL STYLES                                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenTabControl" TargetType="TabControl">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
  </Style>

  <Style TargetType="Hyperlink">
    <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
    <Setter Property="TextDecorations" Value="Underline"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{DynamicResource AccentOmenLightBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="OmenTabItem" TargetType="TabItem">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="16,10"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                  BorderThickness="0,0,0,2" BorderBrush="Transparent" SnapsToDevicePixels="True">
            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <!-- Using BgHover with opacity? Original #15FF6B00. Let's use BgHoverBrush for simplicity as we don't have opacity brush. -->
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SCROLLBAR STYLES                                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenScrollBar" TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Width" Value="8"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid>
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.Thumb>
                <Thumb>
                  <Thumb.Style>
                    <Style TargetType="Thumb">
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="Thumb">
                            <Border Background="#40808080" CornerRadius="4" Margin="1"/> <!-- Neutral gray semi-transparent -->
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </Thumb.Style>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="8"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="OmenScrollViewer" TargetType="ScrollViewer">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollViewer">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0"
                       Style="{StaticResource OmenScrollBar}"
                       Value="{TemplateBinding VerticalOffset}"
                       Maximum="{TemplateBinding ScrollableHeight}"
                       ViewportSize="{TemplateBinding ViewportHeight}"
                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
            <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1"
                       Orientation="Horizontal" Style="{StaticResource OmenScrollBar}"
                       Value="{TemplateBinding HorizontalOffset}"
                       Maximum="{TemplateBinding ScrollableWidth}"
                       ViewportSize="{TemplateBinding ViewportWidth}"
                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- TEXTBLOCK / LABEL STYLES                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenHeading" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="18"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>

  <Style x:Key="OmenSubHeading" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style x:Key="OmenBody" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="22"/>
  </Style>

  <Style x:Key="OmenCaption" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="11"/>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- TOOLTIP STYLE                                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenToolTip" TargetType="ToolTip">
    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6" Padding="{TemplateBinding Padding}">
            <ContentPresenter/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CHECKBOX STYLE                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenCheckBox" TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal">
            <Border x:Name="CheckBorder" Width="18" Height="18" CornerRadius="4"
                    Background="{DynamicResource BgInputBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1" VerticalAlignment="Center">
              <Path x:Name="CheckPath" Data="M 3 8 L 7 12 L 14 4" Stroke="{DynamicResource AccentOmenBrush}"
                    StrokeThickness="2" Visibility="Collapsed" Margin="0" VerticalAlignment="Center"
                    HorizontalAlignment="Center"/>
            </Border>
            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="CheckPath" Property="Visibility" Value="Visible"/>
              <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- NAVIGATION BUTTON (Control Panel Sidebar)                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenNavButton" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="GroupName" Value="NavGroup"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="14,10"
                  Margin="4,2" SnapsToDevicePixels="True">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="NavIcon" Text="{TemplateBinding Tag}" FontSize="16"
                         VerticalAlignment="Center" Margin="0,0,10,0"
                         Foreground="{TemplateBinding Foreground}"/>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
              <!-- Background was #20FF6B00. Use BgHoverBrush? Or InputBrush? -->
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- OPTION RADIO BUTTON (for grouped settings)                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenOptionRadio" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Margin" Value="0,2"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                  Padding="12,8" SnapsToDevicePixels="True" BorderThickness="1"
                  BorderBrush="Transparent">
            <ContentPresenter VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- GROUP CARD (section container)                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenGroupCard" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="16,14"/>
    <Setter Property="Margin" Value="0,0,0,12"/>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- TOGGLE SWITCH (on/off)                                      -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenToggle" TargetType="ToggleButton">
    <Setter Property="Width" Value="44"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid>
            <!-- Track Color. Off state should be visible but distinct from background. Using BorderDefaultBrush. -->
            <Border x:Name="Track" Background="{DynamicResource BorderDefaultBrush}" CornerRadius="12"
                    Width="44" Height="24"/>
            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <!-- On State: Track White, Thumb Black -->
              <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource BgInputBrush}"/>
              <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
              <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SLIDER STYLE                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenSlider" TargetType="Slider">
    <Setter Property="Minimum" Value="0"/>
    <Setter Property="Maximum" Value="100"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid VerticalAlignment="Center">
             <!-- Track Off. Using BgInputBrush. -->
            <Border Height="4" CornerRadius="2" Background="{DynamicResource BgInputBrush}"/>
            <Track x:Name="PART_Track">
              <Track.Thumb>
                <Thumb>
                  <Thumb.Style>
                    <Style TargetType="Thumb">
                      <Setter Property="Width" Value="16"/>
                      <Setter Property="Height" Value="16"/>
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="Thumb">
                            <Ellipse Fill="{DynamicResource AccentOmenBrush}"
                                     Width="16" Height="16"/>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </Thumb.Style>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- STAT CARD (dashboard value display)                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenStatValue" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="28"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>

  <Style x:Key="OmenStatUnit" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Margin" Value="4,0,0,4"/>
    <Setter Property="VerticalAlignment" Value="Bottom"/>
  </Style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- COMBOBOX STYLE                                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <Style x:Key="OmenComboBoxItem" TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                  CornerRadius="4" Margin="2,1" SnapsToDevicePixels="True">
            <ContentPresenter VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenComboBoxToggle" TargetType="ToggleButton">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="ClickMode" Value="Press"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6" SnapsToDevicePixels="True">
            <Path x:Name="Arrow" Data="M 0 0 L 5 5 L 10 0 Z"
                  Fill="{DynamicResource TextSecondaryBrush}"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,12,0"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenComboBox" TargetType="ComboBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="ItemContainerStyle" Value="{StaticResource OmenComboBoxItem}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton x:Name="ToggleButton" Style="{StaticResource OmenComboBoxToggle}"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              Margin="14,8,30,8" VerticalAlignment="Center"
                              HorizontalAlignment="Left"/>
            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
              <Border x:Name="DropDownBorder" Background="{DynamicResource BgCardBrush}"
                      BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                      CornerRadius="6" Padding="2,4" Margin="0,2,0,0"
                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300"
                      Effect="{StaticResource MenuShadow}">
                <ScrollViewer Style="{StaticResource OmenScrollViewer}" SnapsToDevicePixels="True">
                  <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
